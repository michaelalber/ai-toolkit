  // ---------------------------------------------------------------------------
  // Providers — Ollama local inference
  //
  // BEFORE UNCOMMENTING: set these env vars in the Ollama server process.
  // Without them you will hit silent 4K context truncation and tool-call failures.
  // See README.md for setup instructions.
  //
  //   OLLAMA_FLASH_ATTENTION=1       # required for KV cache quantization
  //   OLLAMA_KV_CACHE_TYPE=q8_0     # halves KV cache VRAM; negligible quality loss
  //   OLLAMA_KEEP_ALIVE=30m         # keep model loaded between sessions
  //   OLLAMA_NUM_PARALLEL=1         # single-user: prevents VRAM contention
  //
  // THREE CONTEXT LEVERS THAT MUST AGREE:
  //   options.num_ctx  → overrides Ollama's per-request context (required — Ollama default is 4096)
  //   limit.context    → OpenCode's internal accounting (must equal options.num_ctx)
  //   limit.output     → must be set; if absent OpenCode sends max_tokens=32000 which breaks local models
  // ---------------------------------------------------------------------------
  "provider": {
    //  "ollama": {
