{
  "$schema": "https://opencode.ai/config.json",

  // Default model — adjust to your preferred provider/model
  "model": "github-copilot/claude-sonnet-4.6",

  // ---------------------------------------------------------------------------
  // Agent Configuration
  // build/plan → Claude Sonnet 4.6 — best reasoning for code generation
  // general    → Claude Sonnet 4.6 — strong Q&A and technical guidance
  // explore    → Claude Haiku 4.5 — fastest scan, lowest cost, minimal footprint
  // ---------------------------------------------------------------------------
  "agent": {
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.2,
      "prompt": "MANDATORY FIRST STEP: Before writing any code or answering any technical question, call `search_knowledge` on the grounded-code-mcp MCP server. Use collection \"internal\" for TDD/XP standards, \"dotnet_csharp\" for .NET/C#, \"python\" for Python, \"patterns\" for design patterns. Also call `search_code_examples` for implementation patterns. See AGENTS.md for the full collection map and workflow. Do NOT skip this step."
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.1,
      "prompt": "MANDATORY FIRST STEP: Before planning any implementation, call `search_knowledge` on the grounded-code-mcp MCP server. Use collection \"internal\" for TDD/XP/architecture standards, \"patterns\" for design patterns. See AGENTS.md for the full collection map and workflow. Do NOT skip this step."
    },
    "general": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.3,
      "prompt": "MANDATORY FIRST STEP: Before answering technical questions or writing code, call `search_knowledge` on the grounded-code-mcp MCP server. Use collection \"internal\" for engineering standards, \"dotnet_csharp\" for .NET/C#, \"python\" for Python, \"patterns\" for design patterns. Also call `search_code_examples` for implementation patterns. See AGENTS.md for the full collection map and workflow. Do NOT skip this step."
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "temperature": 0.1
    }
  },

  // ---------------------------------------------------------------------------
  // Permissions
  // ---------------------------------------------------------------------------
  "permission": {
    "read": {
      "*": "allow",
      ".env.example": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets.*": "deny",
      "**/*.secret": "deny",
      "**/*.secrets": "deny",
      "**/.secret*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.jks": "deny",
      "**/*.keystore": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/id_ecdsa*": "deny",
      "**/id_dsa*": "deny",
      "**/master.key": "deny",
      "**/credentials.json": "deny",
      "**/service-account*.json": "deny",
      "**/*.boto": "deny",
      "**/token.json": "deny",
      "**/.htpasswd": "deny",
      "**/.netrc": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.dockerconfigjson": "deny",
      "**/*.kdbx": "deny",
      "**/*.kdb": "deny",
      "**/*.gpg": "deny",
      "**/*.asc": "deny",
      "**/*.tfvars": "deny",
      "**/.vault-token": "deny",
      "**/vault-token": "deny",
      "**/.ssh/**": "deny",
      "**/appsettings.json": "deny",
      "**/appsettings.*.json": "deny",
      "**/web.config": "deny",
      "**/app.config": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "webfetch": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm -rf*": "deny",
      "sudo rm*": "deny",
      "dd*": "deny",
      "mkfs*": "deny",
      "shred*": "deny",
      "wget*": "deny",
      "chmod 777*": "deny",
      "chown*": "deny",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch": "allow",
      "git branch --list*": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git show*": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask",
    "skill": "allow"
  },

  // ---------------------------------------------------------------------------
  // MCP Servers
  // Replace YOUR_USERNAME with your actual username where applicable.
  // ---------------------------------------------------------------------------
  "mcp": {
    // Snyk — security scanning. Install: npm install -g snyk
    "snyk": {
      "type": "local",
      "command": ["/home/YOUR_USERNAME/.npm-global/bin/snyk", "mcp", "-t", "stdio"],
      "enabled": true
    },
    // Microsoft Learn — official MS/Azure documentation
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    },
    // Atlassian (Jira/Confluence) — replace with your own MCP endpoint, or disable
    // "atlassian": {
    //   "type": "remote",
    //   "url": "YOUR_ATLASSIAN_MCP_URL",
    //   "enabled": true
    // },
    // grounded-code-mcp — local RAG server for engineering standards
    // See: https://github.com/YOUR_USERNAME/grounded-code-mcp
    "grounded-code-mcp": {
      "type": "local",
      "command": ["grounded-code-mcp", "serve"],
      "enabled": true
    },
    // semgrep — local SAST scanner for security and code quality
    "semgrep": {
      "type": "local",
      "command": ["uvx", "semgrep", "mcp"],
      "enabled": true
    }
  },

  // ---------------------------------------------------------------------------
  // Providers
  // Ollama — local inference. All models sized for 6GB VRAM (RTX 3060 Mobile).
  // Adjust context limits to match your hardware.
  // ---------------------------------------------------------------------------
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        // Named variants — created via Modelfile with explicit num_ctx 32768
        // Only use these if you have confirmed VRAM headroom at that context length
        "granite3.3-8b-32k": {
          "name": "Granite 3.3 8B 32k (IBM)",
          "tools": true,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "llama3.1-8b-32k": {
          "name": "Llama 3.1 8B 32k (Meta)",
          "tools": true,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },

        // Standard pulls — context capped at 8192 for safe 6GB VRAM operation
        "granite3.3:8b": {
          "name": "Granite 3.3 8B (IBM)",
          "tools": true,
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        "llama3.1:8b": {
          "name": "Llama 3.1 8B (Meta)",
          "tools": true,
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        "phi4-mini": {
          "name": "Phi-4 Mini 3.8B (Microsoft)",
          "tools": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "llama3.2:3b": {
          "name": "Llama 3.2 3B (Meta)",
          "tools": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    }
  }
}
