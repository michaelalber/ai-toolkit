{
  "$schema": "https://opencode.ai/config.json",

  // ---------------------------------------------------------------------------
  // Agent Configuration
  // ---------------------------------------------------------------------------
  "agent": {
    "build": {
      "temperature": 0.2
    },
    "plan": {
      "temperature": 0.1
    },
    "general": {
      "temperature": 0.3
    },
    "explore": {
      "temperature": 0.1
    }
  },

  // ---------------------------------------------------------------------------
  // Permissions
  // ---------------------------------------------------------------------------
  "permission": {
    "read": {
      "*": "allow",
      ".env.example": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets.*": "deny",
      "**/*.secret": "deny",
      "**/*.secrets": "deny",
      "**/.secret*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.jks": "deny",
      "**/*.keystore": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/id_ecdsa*": "deny",
      "**/id_dsa*": "deny",
      "**/master.key": "deny",
      "**/credentials.json": "deny",
      "**/service-account*.json": "deny",
      "**/*.boto": "deny",
      "**/token.json": "deny",
      "**/.htpasswd": "deny",
      "**/.netrc": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.dockerconfigjson": "deny",
      "**/*.kdbx": "deny",
      "**/*.kdb": "deny",
      "**/*.gpg": "deny",
      "**/*.asc": "deny",
      "**/*.tfvars": "deny",
      "**/.vault-token": "deny",
      "**/vault-token": "deny",
      "**/.ssh/**": "deny",
      "**/appsettings.json": "deny",
      "**/appsettings.*.json": "deny",
      "**/web.config": "deny",
      "**/app.config": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "webfetch": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm -rf*": "deny",
      "sudo rm*": "deny",
      "dd*": "deny",
      "mkfs*": "deny",
      "shred*": "deny",
      "wget*": "deny",
      "chmod 777*": "deny",
      "chown*": "deny",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch": "allow",
      "git branch --list*": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git show*": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask",
    "skill": "allow"
  },

  // ---------------------------------------------------------------------------
  // MCP Servers
  // Replace YOUR_USERNAME with your actual username where applicable.
  // ---------------------------------------------------------------------------
