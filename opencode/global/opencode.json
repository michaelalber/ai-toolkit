    //    "name": "Ollama (local)",
    //    "options": {
    //      "baseURL": "http://localhost:11434/v1"
    //    },
    //    "models": {
    //
    //      // ---------------------------------------------------------------
    //      // 8 GB VRAM (e.g. RTX 3070 Mobile, RX 6700M)
    //      // Budget: ~4.8 GB weights + ~0.5 GB KV@8K Q8_0 + ~0.8 GB overhead = ~6.1 GB
    //      // ---------------------------------------------------------------
    //
    //      // Best all-round: highest code quality in sub-10B class (HumanEval 76.0)
    //      "qwen3:8b": {
    //        "name": "Qwen3 8B (Alibaba)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Code-specialized: strong HumanEval, best for pure coding tasks
    //      "qwen2.5-coder:7b": {
    //        "name": "Qwen2.5 Coder 7B",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Agentic-optimized: IBM model designed for tool/RAG-heavy workflows
    //      "granite3.3:8b": {
    //        "name": "Granite 3.3 8B (IBM)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Proven baseline: stable tool calling, broad community testing
    //      "llama3.1:8b": {
    //        "name": "Llama 3.1 8B (Meta)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //
    //      // ---------------------------------------------------------------
    //      // 6 GB VRAM (e.g. RTX 3060 Mobile, RX 6600M)
    //      // Requires OLLAMA_KV_CACHE_TYPE=q8_0 for any num_ctx > 4096 at 7B
