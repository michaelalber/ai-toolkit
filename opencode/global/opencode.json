{
  "$schema": "https://opencode.ai/config.json",

  // Snapshot preserves session history outside the agent's write scope.
  // Supports audit trail requirements (OWASP T8 - Repudiation & Untraceability).
  "snapshot": true,

  // ---------------------------------------------------------------------------
  // Agent Configuration
  // No model pins — select per-session via /models or set OPENCODE_MODEL env var.
  // Ollama models remain available on-demand via /models for any agent.
  // ---------------------------------------------------------------------------
  "agent": {
    "build": {
      "temperature": 0.2
    },
    "plan": {
      "temperature": 0.1
    },
    "general": {
      "temperature": 0.3
    },
    "explore": {
      "temperature": 0.1
    }
  },

  // ---------------------------------------------------------------------------
  // Permissions
  // Pattern matching uses simple glob prefix matching — shell metacharacters
  // (pipes, semicolons, &&) are NOT parsed. Defense against pipe-to-shell attacks
  // relies on "bash": "*": "ask" as the catch-all, requiring manual approval.
  //
  // OWASP threat mapping:
  //   T2  Tool Misuse          — bash catch-all "ask", explicit sudo/su deny
  //   T3  Privilege Compromise — sudo/su deny, no root execution
  //   T8  Repudiation          — snapshot: true (session history preserved)
  //   T11 RCE & Code Attacks   — bash catch-all "ask", plan/explore bash deny
  //   T17 Supply Chain         — pinned model versions, reviewed MCP connections
  // ---------------------------------------------------------------------------
  "permission": {
    "read": {
      "*": "allow",

      // Allowed .NET config — safe for the agent to read for architecture context.
      // These rarely contain raw secrets in modern projects (user-secrets / env vars handle that).
      ".env.example": "allow",
      "**/appsettings.json": "allow",
      "**/appsettings.Development.json": "allow",
      "**/appsettings.Staging.json": "ask",
      "**/launchSettings.json": "allow",

      // Require explicit approval for production config — may contain environment-specific
      // connection strings or feature flags with operational impact (OWASP T3).
      "**/appsettings.Production.json": "ask",
      "**/appsettings.Release.json": "ask",
      "**/web.config": "ask",
      "**/app.config": "ask",

      // --- Secrets and credentials (OWASP T3) ---
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets.*": "deny",
      "**/*.secret": "deny",
      "**/*.secrets": "deny",
      "**/.secret*": "deny",

      // --- Private keys and certificates (OWASP T3) ---
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/*.jks": "deny",
      "**/*.keystore": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/id_ecdsa*": "deny",
      "**/id_dsa*": "deny",

      // --- Cloud and service credentials (OWASP T3) ---
      "**/master.key": "deny",
      "**/credentials.json": "deny",
      "**/service-account*.json": "deny",
      "**/*.boto": "deny",
      "**/token.json": "deny",

      // --- Auth and tool credentials (OWASP T3) ---
      "**/.htpasswd": "deny",
      "**/.netrc": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.dockerconfigjson": "deny",

      // --- Password and key stores (OWASP T3) ---
      "**/*.kdbx": "deny",
      "**/*.kdb": "deny",
      "**/*.gpg": "deny",
      "**/*.asc": "deny",

      // --- IaC secrets (OWASP T3) ---
      "**/*.tfvars": "deny",
      "**/.vault-token": "deny",
      "**/vault-token": "deny",

      // --- SSH directory (OWASP T3) ---
      "**/.ssh/**": "deny",

      // --- Cloud provider credentials (OWASP T3) ---
      "**/.aws/credentials": "deny",
      "**/.aws/config": "ask",
      "**/.kube/config": "deny",
      "**/kubeconfig": "deny",
      "**/.azure/msal_token_cache.json": "deny",

      // --- Infrastructure state files (OWASP T3) ---
      // Terraform state routinely contains plaintext DB passwords and API keys from resource outputs.
      "**/*.tfstate": "deny",
      "**/terraform.tfstate.backup": "deny",

      // --- .NET connection strings (OWASP T3) ---
      // Separate pattern for files explicitly named after connection strings —
      // higher risk than general appsettings.
      "**/connectionstrings.json": "deny",
      "**/*connectionstrings*.json": "deny",
      "**/AppSettingsSecrets.config": "deny",
      "**/ConnectionStrings.config": "deny",

      // --- Database and backup files (OWASP T3, T11) ---
      "**/*.bak": "deny",
      "**/*.sql.bak": "deny",
      "**/*.mdf": "deny",
      "**/*.ldf": "deny"
    },

    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "webfetch": "ask",
    "skill": "allow",

    "edit": "ask",

    // bash: catch-all "ask" is the primary RCE defense (OWASP T2, T11).
    // Note: OpenCode pattern matching uses simple glob prefix — pipe/semicolon
    // metacharacters are NOT evaluated. Pipe-to-shell defense depends entirely
    // on the "ask" approval prompt and user review.
    //
    // sudo/su: explicit deny — privilege escalation from a coding agent session
    // must never be permitted, even accidentally (OWASP T3).
    "bash": {
      "*": "ask",

      // --- Allowed dev tooling (synced with claude/global/settings.local.json) ---
      // Compilers / build tools / debuggers
      "gcc*": "allow",
      "g++*": "allow",
      "make*": "allow",
      "gdb*": "allow",

      // Local LLM runtime
      "ollama*": "allow",

      // Read-only system inspection
      "systemctl status*": "allow",
      "systemctl cat*": "allow",
      "nvidia-smi*": "allow",
      "env*": "allow",
      "echo*": "allow",
      "find*": "allow",
      "grep*": "allow",
      "dpkg -l*": "allow",
      "snap list*": "allow",
      "flatpak list*": "allow",

      // OpenCode introspection / read-only operations
      "opencode --help*": "allow",
      "opencode --version*": "allow",
      "opencode models list*": "allow",
      "opencode run*": "allow",
      "opencode debug config*": "allow",

      // Package / MCP tooling
      "grounded-code-mcp ingest*": "allow",
      "pipx run*": "allow",

      // Narrow sudo exceptions — MUST appear before "sudo *" deny below so the
      // more-specific pattern wins. Each exception is intentional and scoped.
      "sudo systemctl stop*": "allow",
      "sudo systemctl start*": "allow",
      "sudo -u ollama ls*": "allow",

      // --- Privilege escalation denies (OWASP T3) ---
      "sudo *": "deny",
      "su *": "deny",
      "su": "deny",

      // Destructive filesystem / disk operations — explicit deny prevents accidental approval (OWASP T2, T11).
      "rm -rf*": "deny",
      "dd*": "deny",
      "mkfs*": "deny",
      "shred*": "deny",

      // Arbitrary downloads — supply chain risk (OWASP T17).
      "wget*": "deny",

      // Permission / ownership escalation — deny to prevent privilege creep (OWASP T3).
      "chmod 777*": "deny",
      "chown*": "deny",

      // Inline code execution — deny to prevent prompt-injection payload delivery (OWASP T11).
      // These bypass the file-based review path where the user can inspect code before running.
      "python -c *": "deny",
      "python3 -c *": "deny",
      "node -e *": "deny",
      "bash -c *": "deny",
      "sh -c *": "deny",

      // Safe read-only git operations — no approval needed.
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch": "allow",
      "git branch --list*": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git show*": "allow",

      // Destructive git operations — cannot be undone on shared remotes (OWASP T2).
      "git push --force*": "deny",
      "git push -f*": "deny"
    },

    "external_directory": "ask",

    // doom_loop: "ask" prevents runaway autonomous execution (OWASP T4 Resource Overload).
    "doom_loop": "ask"
  },

  // ---------------------------------------------------------------------------
  // MCP Servers
  // Each MCP connection is an extension of the agent's trust boundary (OWASP T16).
  // ---------------------------------------------------------------------------
