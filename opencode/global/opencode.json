  // ---------------------------------------------------------------------------
  // Providers — Ollama local inference
  //
  // BEFORE UNCOMMENTING: set these env vars in the Ollama server process.
  // Without them you will hit silent 4K context truncation and tool-call failures.
  // See README.md for setup instructions.
  //
  //   OLLAMA_FLASH_ATTENTION=1       # required for KV cache quantization
  //   OLLAMA_KV_CACHE_TYPE=q8_0     # halves KV cache VRAM; negligible quality loss
  //   OLLAMA_KEEP_ALIVE=30m         # keep model loaded between sessions
  //   OLLAMA_NUM_PARALLEL=1         # single-user: prevents VRAM contention
  //
  // THREE CONTEXT LEVERS THAT MUST AGREE:
  //   options.num_ctx  → overrides Ollama's per-request context (required — Ollama default is 4096)
  //   limit.context    → OpenCode's internal accounting (must equal options.num_ctx)
  //   limit.output     → must be set; if absent OpenCode sends max_tokens=32000 which breaks local models
  // ---------------------------------------------------------------------------
  "provider": {
    //  "ollama": {
    //    "npm": "@ai-sdk/openai-compatible",
    //    "name": "Ollama (local)",
    //    "options": {
    //      "baseURL": "http://localhost:11434/v1"
    //    },
    //    "models": {
    //
    //      // ---------------------------------------------------------------
    //      // 8 GB VRAM (e.g. RTX 3070 Mobile, RX 6700M)
    //      // Budget: ~4.8 GB weights + ~0.5 GB KV@8K Q8_0 + ~0.8 GB overhead = ~6.1 GB
    //      // ---------------------------------------------------------------
    //
    //      // Best all-round: highest code quality in sub-10B class (HumanEval 76.0)
    //      "qwen3:8b": {
    //        "name": "Qwen3 8B (Alibaba)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Code-specialized: strong HumanEval, best for pure coding tasks
    //      "qwen2.5-coder:7b": {
    //        "name": "Qwen2.5 Coder 7B",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Agentic-optimized: IBM model designed for tool/RAG-heavy workflows
    //      "granite3.3:8b": {
    //        "name": "Granite 3.3 8B (IBM)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // Proven baseline: stable tool calling, broad community testing
    //      "llama3.1:8b": {
    //        "name": "Llama 3.1 8B (Meta)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //
    //      // ---------------------------------------------------------------
    //      // 6 GB VRAM (e.g. RTX 3060 Mobile, RX 6600M)
    //      // Requires OLLAMA_KV_CACHE_TYPE=q8_0 for any num_ctx > 4096 at 7B
    //      // ---------------------------------------------------------------
    //
    //      // Recommended for 6 GB: best quality in the weight budget
    //      "qwen3:4b": {
    //        "name": "Qwen3 4B (Alibaba)",
    //        "tools": true,
    //        "limit": { "context": 8192, "output": 2048 },
    //        "options": { "num_ctx": 8192 }
    //      },
    //      // 7B on 6 GB: only safe with OLLAMA_KV_CACHE_TYPE=q8_0 and num_ctx=4096
    //      "qwen2.5-coder:7b-6gb": {
    //        "name": "Qwen2.5 Coder 7B (6 GB config)",
    //        "tools": true,
    //        "limit": { "context": 4096, "output": 2048 },
    //        "options": { "num_ctx": 4096 }
    //      },
    //      // Lightest tool-capable model: very comfortable on 6 GB
    //      "granite3.3:2b": {
    //        "name": "Granite 3.3 2B (IBM)",
    //        "tools": true,
    //        "limit": { "context": 16384, "output": 2048 },
    //        "options": { "num_ctx": 16384 }
    //      },
    //
    //      // ---------------------------------------------------------------
    //      // Custom Modelfile variants — larger context on 8 GB with KV Q8_0
    //      // Create with: ollama create <name> -f Modelfile
    //      // See README.md for the Modelfile template
    //      // 7B Q4_K_M + 16K Q8_0 KV + overhead ≈ 7.4 GB — safe on 8 GB
