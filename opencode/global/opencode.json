    // Atlassian (Jira/Confluence) — replace with your own MCP endpoint, or disable
    //"atlassian": {
    //  "type": "remote",
    //  "url": "YOUR_ATLASSIAN_MCP_URL",
    //  "enabled": true
    //},
    // grounded-code-mcp — local RAG server for engineering standards
    // See: https://github.com/michaelalber/grounded-code-mcp
    //"grounded-code-mcp": {
    //  "type": "local",
    //  "command": ["grounded-code-mcp", "serve"],
    //  "enabled": true
    //},
    // semgrep — local SAST scanner for security and code quality
    //"semgrep": {
    //  "type": "local",
    //  "command": ["uvx", "semgrep", "mcp"],
    //  "enabled": true
    //}
  },

}
