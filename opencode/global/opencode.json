    //
    //      "qwen3-8b-16k": {
    //        "name": "Qwen3 8B 16K (custom Modelfile)",
    //        "tools": true,
    //        "limit": { "context": 16384, "output": 2048 },
    //        "options": { "num_ctx": 16384 }
    //      },
    //      "granite3.3-8b-16k": {
