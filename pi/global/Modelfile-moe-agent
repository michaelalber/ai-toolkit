# Ollama Modelfile — Qwen3.6 MoE agentic coding agent
#
# Usage:
#   ollama create qwen3.6-35b-a3b-agent -f Modelfile-moe-agent
#   pi --model ollama-lan/qwen3.6-35b-a3b-agent:latest
#
# Swap the FROM line for any Qwen3.6 MoE tag (35b-a3b) or the coder MoE
# (qwen3-coder:30b). Use Modelfile-20b for the dense variants.
#
# MoE models have lightweight attention, so large context is cheap:
# 131072 tokens costs ~6 GB of KV cache on 48 GB unified memory.
#
# IMPORTANT: do NOT drop num_ctx below 65536 for agentic work — tool-call
# history accumulates fast in multi-step sessions.
#
# Env: export OLLAMA_KV_CACHE_TYPE=q8_0 before starting ollama serve

FROM qwen3.6:35b-a3b

# NOTE: do NOT add a TEMPLATE block here. Qwen3.6 ships an Ollama
# renderer/parser pair that handles the chat template, thinking blocks, and
# tool-call parsing; FROM inherits it. The hand-written Qwen3-era template
# that forced "/no_think" is obsolete and overriding it breaks tool calling.
# Turn thinking off on the Pi side instead: "defaultThinkingLevel": "off".

PARAMETER num_ctx 131072

# Low temperature for deterministic code output.
PARAMETER temperature 0.2
PARAMETER top_k 20
PARAMETER top_p 0.9
PARAMETER min_p 0
PARAMETER presence_penalty 1.5
PARAMETER repeat_penalty 1
