# Ollama Modelfile — Qwen3.6 dense agentic coding agent
#
# Usage:
#   ollama create qwen3.6-27b-agent -f Modelfile-20b
#   pi --model ollama-lan/qwen3.6-27b-agent:latest
#
# Swap the FROM line for any dense Qwen3.6 tag (27b, 35b).
# Use Modelfile-moe-agent for the MoE variant (qwen3.6:35b-a3b).
#
# VRAM: ~18 GB at Q4_K_M + 128K KV cache on 48 GB unified memory
# Env:  export OLLAMA_KV_CACHE_TYPE=q8_0 before starting ollama serve

FROM qwen3.6:27b

# NOTE: do NOT add a TEMPLATE block here. Qwen3.6 ships an Ollama
# renderer/parser pair that handles the chat template, thinking blocks, and
# tool-call parsing; FROM inherits it. The hand-written Qwen3-era template
# that forced "/no_think" is obsolete and overriding it breaks tool calling.
# Turn thinking off on the Pi side instead: "defaultThinkingLevel": "off".

# num_ctx MUST be set — Ollama's default is 4096, which tool schemas plus the
# system prompt exhaust before you type anything. Native window is 262144;
# 131072 is the practical ceiling at q8_0 KV cache on 48 GB unified memory.
PARAMETER num_ctx 131072

# Low temperature for deterministic code output.
PARAMETER temperature 0.2
PARAMETER top_k 20
PARAMETER top_p 0.9
PARAMETER min_p 0
PARAMETER presence_penalty 1.5
PARAMETER repeat_penalty 1
