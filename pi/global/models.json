{
  "providers": {
    "ollama-cloud": {
      "baseUrl": "https://ollama.com/api",
      "api": "openai-completions",
      "apiKey": "${OLLAMA_API_KEY}",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "qwen3-coder-next",
          "name": "Qwen3 Coder Next 80B MoE (Ollama Cloud)",
          "_notes": "Large MoE coder — cloud fallback when the local host is unavailable",
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "devstral-2:123b",
          "name": "Devstral 2 123B (Ollama Cloud)",
          "_notes": "Power coding model — Mistral's large coding specialist",
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "devstral-small-2:24b",
          "name": "Devstral Small 2 24B (Ollama Cloud)",
          "_notes": "Fast coding fallback — Mistral small coder for quick tasks",
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 4096
        }
      ]
    },
    "ollama-lan": {
      "baseUrl": "http://YOUR-OLLAMA-HOST:11434/v1",
      "api": "openai-completions",
      "apiKey": "ollama",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false,
        "supportsUsageInStreaming": false,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "qwen3.6-27b-agent:latest",
          "name": "Qwen3.6 27B Agent",
          "_notes": "Agent-tuned dense — primary agentic/build model; built from Modelfile-20b",
          "input": ["text", "image"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "qwen3.6-35b-a3b-agent:latest",
          "name": "Qwen3.6 35B-A3B Agent",
          "_notes": "Agent-tuned fast MoE — explore/search role; built from Modelfile-moe-agent",
          "input": ["text", "image"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "qwen3-coder-30b-agent:latest",
          "name": "Qwen3 Coder 30B Agent",
          "_notes": "Agent-tuned MoE, coder-tuned — code generation, completions, edits",
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "qwen3-vl:30b-a3b",
          "name": "Qwen3-VL 30B-A3B",
          "_notes": "Vision-capable MoE — the vision + tools option; native 262144, kept at 131072 to match the rest",
          "input": ["text", "image"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "devstral:latest",
          "name": "Devstral",
          "_notes": "Mistral coding specialist — agentic coding tasks",
          "input": ["text"],
          "contextWindow": 131072,
          "maxTokens": 8192
        },
        {
          "id": "qwen2.5-coder:7b",
          "name": "Qwen2.5 Coder 7B",
          "_notes": "Fast autocomplete and FIM tasks",
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 4096
        },
        {
          "id": "JetBrains/Mellum-4b-sft-all:latest",
          "name": "Mellum 4B",
          "_notes": "JetBrains FIM completion model",
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 2048
        }
      ]
    }
  }
}
