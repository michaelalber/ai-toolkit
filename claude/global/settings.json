{
  "skillListingBudgetFraction": 0.03,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-bash-exec.sh"
          }
        ]
      },
      {
        "matcher": "^(Write|Edit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-credentials.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/audit-bash.sh"
          }
        ]
      },
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-write-check.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  }
}
